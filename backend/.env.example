# === 应用 ===
# 生产请设为 false，避免 500 响应泄露异常细节
DEBUG=true

# === 鉴权（管理端必填）===
# 未配置时 /api 管理接口返回 503
# 请求头：X-Admin-Token 或 Authorization: Bearer <token>
# 前端：设置页「管理鉴权」或 VITE_ONTOMETA_ADMIN_TOKEN
ONTOMETA_ADMIN_TOKEN=dev-admin-token-change-me

# 可选：外部 API Key 哈希 pepper；变更后须重新生成全部 App Key
# API_KEY_HASH_PEPPER=

# === 数据库 ===
# 开发用 SQLite；生产 / Docker Compose 建议 PostgreSQL：
# DATABASE_URL=postgresql+psycopg://ontometa:ontometa@localhost:5432/ontometa
DATABASE_URL=sqlite:///./ontometa.db

# === DataHub ===
USE_MOCK_DATAHUB=false
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_FRONTEND_URL=http://localhost:9002
# DATAHUB_TOKEN=
# DataHub 拉取并发上限
# DATAHUB_MAX_CONCURRENCY=5

# === LLM ===
# true：规则引擎代替 LLM（本地无 Key 时推荐）
USE_MOCK_LLM=true
# OPENAI_API_KEY=  # 也可在「设置」页面配置 DeepSeek 等服务
# OPENAI_MODEL=gpt-4o-mini
# LLM_TIMEOUT_SECONDS=300

# === 草稿生成并发 ===
# MAX_CONCURRENT_DRAFT_GENERATIONS=2

# === 外部 API / MCP ===
# 每应用每分钟默认请求上限（进程内固定窗口；应用可覆盖；<=0 关闭）
# EXTERNAL_API_RATE_LIMIT_PER_MINUTE=60

# === CORS（JSON 数组；一般无需改）===
# CORS_ORIGINS=["http://localhost:5180","http://localhost:5173","http://localhost:3000"]
